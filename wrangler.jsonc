{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sevens-game",
  "compatibility_date": "2026-03-29",
  "observability": {
    "enabled": true,
  },
  "build": {
    "command": "pnpm install --frozen-lockfile && pnpm build",
  },
  "assets": {
    "directory": "./.output/public/",
    "not_found_handling": "single-page-application",
  },
}
